// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            BigInt    @id @default(autoincrement())
  email         String    @unique(map: "email") @db.VarChar(50)
  password      String    @db.VarChar(255)
  name          String    @db.VarChar(100)
  gender        Gender
  birthDate     DateTime  @map("birth_date") @db.Date
  address       String    @db.Text
  phoneNumber   String?   @map("phone_num") @db.VarChar(20)
  point         Int?
  status        Int?
  inactiveDate  DateTime? @map("inactive_date")
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime(6)

  preferences UserFoodCategory[]

  @@map("user")
}

enum Gender {
  FEMALE
  MALE
}

model FoodCategory {
  id   BigInt   @id @default(autoincrement())
  name String   @db.VarChar(20)

  preferences UserFoodCategory[]

  @@map("food_category")
}

model UserFoodCategory {
  id             BigInt       @id @default(autoincrement())
  user           User         @relation(fields: [userId], references: [id])
  userId         BigInt       @map("user_id")
  food           FoodCategory @relation(fields: [foodId], references: [id])
  foodId         BigInt       @map("food_id")
  createdAt      DateTime      @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.DateTime(6)

  @@index([foodId])
  @@index([userId])
  @@map("user_food_category")
}